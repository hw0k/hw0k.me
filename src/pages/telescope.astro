---
import { getCollection } from "astro:content";
import Layout from "~/components/layout.astro";

const items = await getCollection('telescope-entries');
const sortedItems = items.toSorted((a, b) => b.data.savedAt.getTime() - a.data.savedAt.getTime());

const sourceLabels: Record<string, string> = {
  spotify: 'Spotify ❤️',
  github: 'GitHub ⭐️',
  raindrop: 'Raindrop 🔖',
};

const grouped: Record<string, typeof sortedItems> = {};
for (const item of sortedItems) {
  const date = item.data.savedAt.toISOString().slice(0, 10);
  if (!grouped[date]) grouped[date] = [];
  grouped[date].push(item);
}

const groupedEntries = Object.entries(grouped);
---

<Layout title="telescope">
  <div class="container mx-auto flex flex-col gap-12">
    {groupedEntries.map(([date, dateItems]) => (
      <section class="flex flex-col gap-4">
        <p class="text-sm text-theme-muted">{date}</p>
        <div class="flex flex-col gap-4">
          {dateItems.map(item => (
            <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="group flex flex-row items-center gap-3 min-w-0">
              {item.data.thumbnailUrl && (
                <img src={item.data.thumbnailUrl} alt={item.data.title} class="w-10 h-10 rounded object-cover shrink-0" />
              )}
              <div class="flex flex-col min-w-0">
                <span class="text-xs text-theme-muted">{sourceLabels[item.data.source]}</span>
                <h3 class="text-base text-theme-heading font-bold group-hover:underline truncate">{item.data.title}</h3>
                {item.data.description && (
                  <p class="text-sm text-theme-muted truncate">{item.data.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
    {groupedEntries.length === 0 && (
      <p class="text-theme-muted text-sm">아직 항목이 없습니다.</p>
    )}
  </div>
</Layout>
