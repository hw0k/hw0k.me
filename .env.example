# Spotify (OAuth)
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Set Redirect URI to http://localhost:3000/callback
# 3. Authorize: https://accounts.spotify.com/authorize?client_id=YOUR_CLIENT_ID&response_type=code&redirect_uri=http://localhost:3000/callback&scope=user-library-read
# 4. Exchange code for tokens:
#    curl -X POST https://accounts.spotify.com/api/token \
#      -H "Content-Type: application/x-www-form-urlencoded" \
#      -u "CLIENT_ID:CLIENT_SECRET" \
#      -d "grant_type=authorization_code&code=CODE&redirect_uri=http://localhost:3000/callback"
# 5. Save refresh_token below
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# GitHub (Personal Access Token)
# Create at https://github.com/settings/tokens with no scopes needed for public starred repos
GITHUB_TOKEN=

# Raindrop (Test Token or Bearer Token)
# Create at https://app.raindrop.io/settings/integrations
RAINDROP_TOKEN=
